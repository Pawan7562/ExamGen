{
  "name": "exam-monitoring-backend",
  "version": "1.0.0",
  "description": "Production-ready backend for Exam Monitoring System",
  "main": "server.production.js",
  "scripts": {
    "start": "NODE_ENV=production node server.production.js",
    "dev": "NODE_ENV=development nodemon server.js",
    "build": "echo 'No build step required for Node.js'",
    "test": "NODE_ENV=test jest --detectOpenHandles",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:coverage": "NODE_ENV=test jest --coverage",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "security:check": "npm audit",
    "security:fix": "npm audit fix",
    "db:seed": "node scripts/seed.js",
    "db:migrate": "node scripts/migrate.js",
    "logs": "tail -f logs/access.log",
    "errors": "tail -f logs/errors.log"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.10.0",
    "express-mongo-sanitize": "^2.2.0",
    "xss": "^1.0.14",
    "hpp": "^0.2.3",
    "morgan": "^1.10.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.4",
    "twilio": "^4.14.0",
    "multer": "^1.4.5-lts.1",
    "joi": "^17.9.2",
    "express-validator": "^7.0.1",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "cluster": "^0.7.7",
    "pm2": "^5.3.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.2",
    "supertest": "^6.3.3",
    "eslint": "^8.46.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.28.0",
    "@types/jest": "^29.5.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "exam",
    "monitoring",
    "proctoring",
    "education",
    "nodejs",
    "express",
    "mongodb"
  ],
  "author": "Exam Monitoring Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pawankumaryadav75628697-bot/Exam-monitoring.git"
  },
  "bugs": {
    "url": "https://github.com/pawankumaryadav75628697-bot/Exam-monitoring/issues"
  },
  "homepage": "https://github.com/pawankumaryadav75628697-bot/Exam-monitoring#readme"
}
