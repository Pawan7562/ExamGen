{
  "name": "exammonitor-backend",
  "version": "1.0.0",
  "description": "Backend for ExamMonitor application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "security-check": "npm audit",
    "build": "echo 'No build step required for Node.js'",
    "docker:build": "docker build -t exammonitor-backend .",
    "docker:run": "docker run -p 5001:5001 exammonitor-backend"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dockerode": "^4.0.9",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.8.1",
    "express-validator": "^7.2.1",
    "helmet": "^7.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "mongoose-paginate-v2": "^1.9.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "react-toastify": "^11.0.5",
    "socket.io": "^4.8.1",
    "tar-stream": "^3.1.7",
    "twilio": "^5.10.2",
    "uuid": "^9.0.1",
    "vm2": "^3.9.19",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "eslint": "^8.50.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.28.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "exam",
    "monitoring",
    "authentication",
    "production",
    "enterprise"
  ],
  "author": "ExamMonitor Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
