  "repository": {
    "type": "git",
    "url": "https://github.com/exam-monitor/exam-monitoring-system.git"
  },
  "bugs": {
    "url": "https://github.com/exam-monitor/exam-monitoring-system/issues"
  },
  "homepage": "https://exam-monitor.com",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  }
