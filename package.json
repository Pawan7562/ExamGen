{
  "name": "exam-monitoring-system",
  "description": "Professional Online Examination Monitoring System with AI-Powered Proctoring",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "build": "npm install && cd frontend && npm install && cd ../backend && npm install && cd ../frontend && npm run build",
    "start": "node api/server.cjs",
    "lint": "cd frontend && npm run lint",
    "preview": "cd frontend && npm run preview",
    "backend": "cd backend && node server.js",
    "install-all": "npm install && cd frontend && npm install"
  },
  "keywords": [
    "exam",
    "monitoring",
    "proctoring",
    "education",
    "react",
    "frontend",
    "backend",
    "online-examination",
    "academic-integrity",
    "ai-proctoring",
    "cheating-detection",
    "professional-education"
  ],
  "author": "Exam Monitor Development Team",
