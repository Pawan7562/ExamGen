{
  "name": "exam-monitoring-frontend",
  "version": "1.0.0",
  "description": "Production-ready frontend for Exam Monitoring System",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.js",
    "build": "vite build --config vite.config.production.js",
    "preview": "vite preview --config vite.config.production.js",
    "build:analyze": "vite build --config vite.config.production.js && npx vite-bundle-analyzer dist/stats.html",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext js,jsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "security:check": "npm audit",
    "security:fix": "npm audit fix",
    "optimize": "npm run build && npm run build:analyze"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.15.0",
    "antd": "^5.8.6",
    "@ant-design/icons": "^5.2.6",
    "axios": "^1.5.0",
    "dayjs": "^1.11.9",
    "@monaco-editor/react": "^4.5.2",
    "recharts": "^2.8.0",
    "react-query": "^3.39.3",
    "zustand": "^4.4.1",
    "react-hook-form": "^7.45.4",
    "react-hot-toast": "^2.4.1",
    "framer-motion": "^10.16.4",
    "lodash": "^4.17.21",
    "classnames": "^2.3.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "vite": "^4.4.5",
    "vitest": "^0.34.4",
    "@vitest/ui": "^0.34.4",
    "@testing-library/react": "^13.4.0",
    "@testing-library/jest-dom": "^6.1.2",
    "@testing-library/user-event": "^14.4.3",
    "jsdom": "^22.1.0",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "prettier": "^3.0.2",
    "typescript": "^5.0.2",
    "vite-bundle-analyzer": "^0.7.0",
    "rollup-plugin-visualizer": "^5.9.2",
    "terser": "^5.19.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "keywords": [
    "exam",
    "monitoring",
    "proctoring",
    "education",
    "react",
    "vite",
    "antd"
  ],
  "author": "Exam Monitoring Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pawankumaryadav75628697-bot/Exam-monitoring.git"
  },
  "bugs": {
    "url": "https://github.com/pawankumaryadav75628697-bot/Exam-monitoring/issues"
  },
  "homepage": "https://www.pkthenexgenexam.xyz"
}
